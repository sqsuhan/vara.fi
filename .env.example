# Deployer private key (no 0x prefix needed for some tools, but Hardhat requires 0x)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Arc Testnet RPC (default already set in hardhat.config.js)
ARC_RPC_URL=https://rpc.testnet.arc.network

# ArcScan API key for contract verification (optional)
ARCSCAN_API_KEY=YOUR_ARCSCAN_API_KEY

# ─── Frontend env ─────────────────────────────────────────────────────────────
# Paste deployed contract addresses here after running the deploy script
VITE_LENDING_POOL_ADDRESS=0x
VITE_COLLATERAL_TOKEN_ADDRESS=0x
VITE_USDC_ADDRESS=0x
VITE_ORACLE_ADDRESS=0x
# rebuild
